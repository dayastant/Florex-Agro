# ==========================================
# Root .gitignore for Florex Agro Mono-repo
# ==========================================

# ------------------------------------------
# OS Metadata
# ------------------------------------------
.DS_Store
Thumbs.db
*.pem

# ------------------------------------------
# IDEs & Editors (VS, VS Code, Rider, WebStorm)
# ------------------------------------------
.vs/
.idea/
.vscode/
*.code-workspace
*.suo
*.user
*.userosscache
*.sln.docstates
*.rsuser
*.ntvs*
*.njsproj
*.sw?

# ------------------------------------------
# Node / Frontend / Mobile dependencies & build artifacts
# ------------------------------------------
**/node_modules/
**/dist/
**/dist-ssr/
**/web-build/
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.local
.env*.local

# ------------------------------------------
# .NET / Backend build artifacts
# ------------------------------------------
**/[Db]in/
**/[Oo]bj/
**/[Dd]ebug/
**/[Dd]ebugPublic/
**/[Rr]elease/
**/[Rr]eleases/
x64/
x86/
**/[Aa]rm/
**/[Aa]rm64/
project.lock.json
project.fragment.lock.json
artifacts/
ScaffoldingReadMe.txt
*.nupkg
*.snupkg
*.binlog
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.VisualState.xml
TestResult.xml
nunit-*.xml

# ------------------------------------------
# Expo / Mobile specific ignores
# ------------------------------------------
Mobile/.expo/
Mobile/expo-env.d.ts
Mobile/.kotlin/
Mobile/*.orig.*
Mobile/*.jks
Mobile/*.p8
Mobile/*.p12
Mobile/*.key
Mobile/*.mobileprovision
Mobile/.metro-health-check*
Mobile/app-example/
Mobile/ios/
Mobile/android/
*.tsbuildinfo
